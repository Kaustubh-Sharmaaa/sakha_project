{
  "info": {
    "name": "Sakha Product API",
    "_postman_id": "sakha-product-api-v1",
    "description": "Full test collection for the Sakha Product API. Run Auth > Register then Auth > Login first — the token is saved automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",    "value": "http://localhost:8080/api/v1" },
    { "key": "token",       "value": "" },
    { "key": "product_id",  "value": "" },
    { "key": "variant_id",  "value": "" },
    { "key": "category_id", "value": "" },
    { "key": "brand_id",    "value": "" },
    { "key": "cart_id",     "value": "" },
    { "key": "order_id",    "value": "" },
    { "key": "wishlist_id", "value": "" },
    { "key": "review_id",   "value": "" },
    { "key": "coupon_code", "value": "SAVE10" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "var r = pm.response.json();",
            "if (r.access_token) {",
            "  pm.collectionVariables.set('token', r.access_token);",
            "  console.log('Token saved');",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@sakha.com\",\n  \"password\": \"Sakha123!\",\n  \"name\": \"Admin User\",\n  \"role\": \"admin\"\n}" },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "var r = pm.response.json();",
            "if (r.access_token) {",
            "  pm.collectionVariables.set('token', r.access_token);",
            "  console.log('Token saved');",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@sakha.com\",\n  \"password\": \"Sakha123!\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth","me"] }
          }
        }
      ]
    },

    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "event": [{ "listen": "test", "script": { "exec": [
            "var r = pm.response.json();",
            "if (r.id) pm.collectionVariables.set('product_id', r.id);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Classic White Tee\",\n  \"description\": \"A comfortable everyday t-shirt\",\n  \"sku\": \"TEE-WHITE-001\",\n  \"status\": \"draft\",\n  \"tags\": [\"clothing\", \"basics\"],\n  \"metadata\": {}\n}" },
            "url": { "raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"] }
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/products?page=1&limit=20", "host": ["{{base_url}}"], "path": ["products"], "query": [
              { "key": "page", "value": "1" },
              { "key": "limit", "value": "20" },
              { "key": "category_id", "value": "", "disabled": true },
              { "key": "brand_id", "value": "", "disabled": true },
              { "key": "status", "value": "active", "disabled": true }
            ]}
          }
        },
        {
          "name": "Get Product",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/products/{{product_id}}", "host": ["{{base_url}}"], "path": ["products","{{product_id}}"] }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Classic White Tee (Updated)\",\n  \"tags\": [\"clothing\", \"basics\", \"sale\"]\n}" },
            "url": { "raw": "{{base_url}}/products/{{product_id}}", "host": ["{{base_url}}"], "path": ["products","{{product_id}}"] }
          }
        },
        {
          "name": "Publish Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/products/{{product_id}}/publish", "host": ["{{base_url}}"], "path": ["products","{{product_id}}","publish"] }
          }
        },
        {
          "name": "Unpublish Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/products/{{product_id}}/unpublish", "host": ["{{base_url}}"], "path": ["products","{{product_id}}","unpublish"] }
          }
        },
        {
          "name": "Duplicate Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"new_name\": \"Classic White Tee (Copy)\"\n}" },
            "url": { "raw": "{{base_url}}/products/{{product_id}}/duplicate", "host": ["{{base_url}}"], "path": ["products","{{product_id}}","duplicate"] }
          }
        },
        {
          "name": "Update SEO",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"meta_title\": \"Classic White Tee | Sakha\",\n  \"meta_description\": \"Shop our best-selling everyday t-shirt.\",\n  \"slug\": \"classic-white-tee\"\n}" },
            "url": { "raw": "{{base_url}}/products/{{product_id}}/seo", "host": ["{{base_url}}"], "path": ["products","{{product_id}}","seo"] }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/products/{{product_id}}", "host": ["{{base_url}}"], "path": ["products","{{product_id}}"] }
          }
        }
      ]
    },

