# ── SurrealDB ──────────────────────────────────────────────────────────────────
# Local dev:  ws://localhost:8000
# Docker:     ws://surrealdb:8000
SURREAL_URL=ws://localhost:8000
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=sakha
SURREAL_DB=products

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Storage ────────────────────────────────────────────────────────────────────
MEDIA_DIR=media
MAX_UPLOAD_MB=20

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=Sakha Product API
API_PREFIX=/api/v1
DEBUG=false
# Tighten in production — replace * with your actual frontend origin
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Auth Microservice ──────────────────────────────────────────────────────────
# Local dev:  http://localhost:8001
# Docker:     http://auth-api:8001
AUTH_API_BASE=http://localhost:8001
