# ── SurrealDB ──────────────────────────────────────────────────────────────────
# Local dev:  ws://localhost:8000/rpc
# Docker:     ws://surrealdb:8000/rpc
SURREAL_URL=ws://localhost:8000/rpc
SURREAL_NAMESPACE=sakha
SURREAL_DB=products
SURREAL_USERNAME=root
SURREAL_PASSWORD=root

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_HOURS=24

# ── App URLs ───────────────────────────────────────────────────────────────────
# APP_BASE_URL is embedded in the email verification link sent to users.
# Local dev:  http://localhost:8001
# Docker:     http://localhost  (nginx handles /auth routing)
APP_BASE_URL=http://localhost:8001

# FRONTEND_BASE_URL is embedded in the password reset link sent to users.
# Local dev:  http://localhost:3000
# Docker:     http://localhost
FRONTEND_BASE_URL=http://localhost:3000
PASSWORD_RESET_PATH=/?view=reset-password

# ── SMTP ───────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=no-reply@yourdomain.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ── Token TTLs ─────────────────────────────────────────────────────────────────
EMAIL_VERIFICATION_TTL_SECONDS=3600
PASSWORD_RESET_TTL_SECONDS=1800
